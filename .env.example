# Server
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wine_inventory
JWT_SECRET=change-me-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:5173

# Client (Vite prefix required)
VITE_API_URL=http://localhost:3001
